{
  "name": "dreamloops-monorepo",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "dreamloops-monorepo",
      "version": "0.1.0",
      "license": "Apache-2.0",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=18.17.0"
      }
    },
    "node_modules/@dreamloops/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@dreamloops/okf-exporter": {
      "resolved": "packages/okf-exporter",
      "link": true
    },
    "node_modules/@dreamloops/runtime": {
      "resolved": "packages/runtime",
      "link": true
    },
    "node_modules/@dreamloops/warper-keeper": {
      "resolved": "packages/warper-keeper",
      "link": true
    },
    "packages/cli": {
      "name": "@dreamloops/cli",
      "version": "0.1.0",
      "license": "Apache-2.0",
      "dependencies": {
        "@dreamloops/runtime": "0.1.0"
      },
      "bin": {
        "dreamloops": "src/cli.js"
      },
      "engines": {
        "node": ">=18.17.0"
      }
    },
    "packages/okf-exporter": {
      "name": "@dreamloops/okf-exporter",
      "version": "0.1.0",
      "license": "Apache-2.0",
      "bin": {
        "dreamloops-okf": "src/cli.js"
      },
      "engines": {
        "node": ">=18.17.0"
      }
    },
    "packages/runtime": {
      "name": "@dreamloops/runtime",
      "version": "0.1.0",
      "license": "Apache-2.0",
      "engines": {
        "node": ">=18.17.0"
      }
    },
    "packages/warper-keeper": {
      "name": "@dreamloops/warper-keeper",
      "version": "0.1.0",
      "license": "Apache-2.0",
      "engines": {
        "node": ">=20.19.0"
      }
    }
  }
}
